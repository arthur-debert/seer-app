{
	"name": "seer",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@10.29.3",
	"scripts": {
		"build:wasm": "wasm-pack build src-tauri/seer-viewer-wasm --target web --out-dir pkg --no-typescript",
		"build:editor-wasm": "wasm-pack build src-tauri/seer-editor-wasm --target web --out-dir pkg",
		"build:all-wasm": "pnpm build:wasm && pnpm build:editor-wasm",
		"fetch:model": "bash scripts/fetch-segformer-model.sh",
		"dev": "pnpm build:all-wasm && vite dev",
		"build": "pnpm build:all-wasm && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"tauri": "tauri",
		"prepare": "lefthook install",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "bash scripts/fetch-segformer-model.sh && playwright test",
		"check:frontend": "bash scripts/check-frontend.sh",
		"check:rust": "bash scripts/check-rust.sh"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	},
	"dependencies": {
		"@xyflow/svelte": "^1.5.2",
		"libraw-wasm": "^1.1.2",
		"onnxruntime-web": "^1.21.0",
		"svelte-dnd-action": "^0.9.69"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@iconify-json/material-symbols": "^1.2.60",
		"@iconify-json/ph": "^1.2.2",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.51.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.0",
		"@tsconfig/svelte": "^5.0.7",
		"@types/node": "^25.2.3",
		"@webgpu/types": "^0.1.69",
		"bits-ui": "^2.15.5",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.3.0",
		"lefthook": "^2.1.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.55.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18"
	}
}
